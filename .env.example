# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=zoowilly.com.ua,www.zoowilly.com.ua
APP_HOSTNAME=zoowilly.com.ua

# CSRF — must match your domain(s)
CSRF_TRUSTED_ORIGINS=https://zoowilly.com.ua,https://www.zoowilly.com.ua

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=zoowilly
POSTGRES_USER=zoowilly
POSTGRES_PASSWORD=change-me-to-strong-password

# Set automatically by docker-compose; do not set manually
# DATABASE_URL=postgres://zoowilly:<password>@db:5432/zoowilly

# SSL between app and DB (false = internal Docker network, no SSL needed)
DB_SSL=false

# ─── Google Places API (імпорт відгуків) ─────────────────────────────────────
# GOOGLE_PLACES_API_KEY=your-key-here

# ─── Security ────────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=true

# ─── Media ───────────────────────────────────────────────────────────────────
# For local Docker: media stored on volume (default)
# For S3 (optional, future):
# USE_S3=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-central-1
